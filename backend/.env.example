# =============================================================================
# IZING — Backend (.env)
# Modelo completo alinhado com docs/INSTALL_VPS_UBUNTU_20_22.md
#
# Copiar:  cp .env.example .env
# JWT:     openssl rand -base64 32  (execute 2x para JWT_SECRET e JWT_REFRESH_SECRET)
# WhatsApp: somente Baileys — wwebjs, Wuzapi e CHROME_BIN foram removidos
# =============================================================================

# --- Ambiente ---
NODE_ENV=dev
# NODE_ENV=production

# --- WhatsApp (Baileys only) ---
USE_BAILEYS=true
# BAILEYS_LOG_LEVEL=silent
# CHECK_INTERVAL=10000
# BAILEYS_VERBOSE=false
# LOG_LEVEL=info

# --- URLs (ajuste em produção) ---
BACKEND_URL=http://localhost:3000
# BACKEND_URL=https://backend.seusite.com.br

FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://izing.seusite.com.br

# Origens extras no CORS (vírgula)
# CORS_ORIGINS=http://192.168.1.10:5173

PROXY_PORT=443
PORT=3000

# --- PostgreSQL ---
DB_DIALECT=postgres
DB_TIMEZONE=-03:00
DB_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_USER=izing
POSTGRES_PASSWORD=123@mudar
POSTGRES_DB=postgres

# Pool (opcional)
# POSTGRES_POOL_MAX=100
# POSTGRES_POOL_MIN=10
# POSTGRES_POOL_ACQUIRE=30000
# POSTGRES_POOL_IDLE=10000

# --- JWT (obrigatório — gere valores únicos) ---
JWT_SECRET=ALTERE_COM_openssl_rand_base64_32
JWT_REFRESH_SECRET=ALTERE_COM_openssl_rand_base64_32

# --- Redis ---
IO_REDIS_SERVER=localhost
IO_REDIS_PORT=6379
IO_REDIS_DB_SESSION=2
IO_REDIS_PASSWORD=123@mudar
# IO_REDIS_USERNAME=

# --- Delays aleatórios (envio / bot) ---
MIN_SLEEP_BUSINESS_HOURS=10000
MAX_SLEEP_BUSINESS_HOURS=20000
MIN_SLEEP_AUTO_REPLY=4000
MAX_SLEEP_AUTO_REPLY=6000
MIN_SLEEP_INTERVAL=2000
MAX_SLEEP_INTERVAL=5000

# --- RabbitMQ (opcional — WABA360 / Messenger; não precisa para WhatsApp Baileys) ---
# RABBITMQ_DEFAULT_USER=admin
# RABBITMQ_DEFAULT_PASS=123@mudar
# AMQP_URL=amqp://admin:123@mudar@localhost:5672?connection_attempts=5&retry_delay=5

# --- WABA 360dialog (opcional) ---
API_URL_360=https://waba-sandbox.360dialog.io

# --- Super admin / domínio ---
ADMIN_DOMAIN=izing.io

# --- Facebook / Messenger (opcional) ---
VUE_FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET_KEY=

# --- Limites do tenant ---
USER_LIMIT=99
CONNECTIONS_LIMIT=99

# --- Atendimento automático (opcional) ---
# TIMEZONE=America/Sao_Paulo
# PENDING_TICKET_GREETING_ENABLED=true
# PENDING_TICKET_GREETING_MESSAGE=
# AUTO_ATTENDANCE_MESSAGE_COOLDOWN_HOURS=24
