# Em dev a URL é resolvida automaticamente (mesmo host da página + porta 3000).
# Use VITE_API_URL apenas para override em produção ou proxy customizado.
VITE_API_URL=http://localhost:3000
VITE_API_PORT=3000

# Messenger / Facebook (mesmo App ID do backend VUE_FACEBOOK_APP_ID)
VITE_FACEBOOK_APP_ID=
